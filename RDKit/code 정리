    m.SetProp("LogP", f"logP: {logp:.3f}") # property 설정할 때는 string(글자 데이터)으로 넣어주어야 한다. 

## x.GetProp() 괄호 속 label 이름 적기
img=Draw.MolsToGridImage(subms,
                         molsPerRow=4,
                         subImgSize=(300, 300),
                         legends=[x.GetProp("LogP") for x in subms])
