# 4. 글리시리진 3차원 구조 생성
from rdkit import Chem
from rdkit.Chem import AllChem

## 4-1.  GL을 글리시리진의 smiles 파일을 mol file로 저장
GL_x = Chem.MolFromSmiles('C[C@]12CC[C@](C[C@H]1C3=CC(=O)[C@@H]4[C@]5(CC[C@@H](C([C@@H]5CC[C@]4([C@@]3(CC2)C)C)(C)C)O[C@@H]6[C@@H]([C@H]([C@@H]([C@H](O6)C(=O)O)O)O)O[C@H]7[C@@H]([C@H]([C@@H]([C@H](O7)C(=O)O)O)O)O)C)(C)C(=O)O')

## 4-2. # 수소 원자 추가
GL=Chem.AddHs(GL_x)

## 4-3. 분자의 3차원 구조 만들기 (EmbedMolecule => AllChem이라는 모듈에 존재)
from rdkit.Chem import AllChem
AllChem.EmbedMolecule(GL)

## 4-4. EmbedMolecule로 얻은 근사적인 3차원 구조를 최적화하는 과정
status = AllChem.MMFFOptimizeMolecule(GL,maxIters=1000)
print(status)

## 4-5. pdb 파일을 pdbqt 파일 형식으로 변환
