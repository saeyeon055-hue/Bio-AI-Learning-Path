< 바로 Lysine(아민기) 노출도 분석 시작 >
pdb_path = "/content/drive/MyDrive/Docking_Project/1LFG.pdb"

if os.path.exists(pdb_path):
    parser = PDBParser(QUIET=True)
    structure = parser.get_structure("1LFG", pdb_path)
    model = structure[0]
    
    # DSSP 계산 (SASA) - 코랩의 mkdssp 경로 지정
    dssp = DSSP(model, pdb_path, dssp='mkdssp')
    
    lysine_results = []
    for key in dssp.keys():
        res_info = dssp[key]
        if res_info[1] == 'K':  # K = Lysine
            # (잔기번호, 아미노산, 상대적 노출도)
            lysine_results.append((key[1], res_info[3]))
            
    # 노출도 높은 순서로 정렬
    lysine_results.sort(key=lambda x: x[1], reverse=True)
    
    print("\n--- [반응 가능성이 높은 Lysine(아민기) TOP 10] ---")
    for rank, (num, exp) in enumerate(lysine_results[:10]):
        status = "⭐ 명당" if exp >= 0.5 else "반응가능"
        print(f"Rank {rank+1}: Lysine {num}번 (노출도: {exp:.2f}) [{status}]")
else:
    print(f"❌ 파일을 찾을 수 없습니다: {pdb_path}")

