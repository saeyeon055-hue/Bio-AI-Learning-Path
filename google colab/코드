import os

# --- [설정: 파일 경로 및 타겟 Lysine 번호] ---
base_path = "/content/drive/MyDrive/Docking_Project"
receptor_path = os.path.join(base_path, "1LFG.pdbqt")

# Rank 1~20번 Lysine 번호 리스트
target_lysine_numbers = [
    691, 416, 630, 676, 579, 661, 484, 28, 280, 516,
    100, 73, 243, 567, 454, 296, 564, 656, 285, 241
]

def extract_all_lys_coords(pdbqt_path, lys_list):
    if not os.path.exists(pdbqt_path):
        print(f"❌ 파일을 찾을 수 없습니다: {pdbqt_path}")
        return

    results = []
    found_count = 0

    > 파일 읽기
    with open(pdbqt_path, 'r') as f:
        lines = f.readlines()

    print(f"🔍 {len(lys_list)}개의 Lysine 좌표 추출을 시작합니다...\n")

    for rank, res_num in enumerate(lys_list, 1):
        coord_found = False
        for line in lines:
            if line.startswith("ATOM"):
                try:
                    # PDBQT 표준 컬럼 (22-26: 잔기번호, 12-16: 원자이름)
                    current_res_num = int(line[22:26].strip())
                    atom_name = line[12:16].strip()

                    if current_res_num == res_num and atom_name == "NZ":
                        # X, Y, Z 좌표 (30-38, 38-46, 46-54)
                        x = float(line[30:38].strip())
                        y = float(line[38:46].strip())
                        z = float(line[46:54].strip())

                        results.append((rank, res_num, x, y, z))
                        print(f"✅ Rank {rank} (Lys{res_num}): ({x}, {y}, {z}) 추출 성공")
                        coord_found = True
                        found_count += 1
                        break
                except:
                    continue

        if not coord_found:
            print(f"⚠️ Rank {rank} (Lys{res_num}): NZ 원자를 찾지 못했습니다.")
            results.append((rank, res_num, None, None, None))

    > --- [최종 출력 결과 생성] ---
    print("\n" + "="*50)
    print("📍 아래 리스트를 복사해서 다음 단계 코드에 넣어주세요!")
    print("="*50 + "\n")
    print("lys_coords_list = [")
    for res in results:
        print(f"    {res},")
    print("]")
    print(f"\n총 {found_count}개의 좌표 추출 완료.")

> 코드 실행
extract_all_lys_coords(receptor_path, target_lysine_numbers)

