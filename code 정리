# Smiles로 분자 만들기
Chem.MolFromSmiles()

# 수소 원자 추가하기
Chem.AddHs()

# 분자 데이터를 텍스트로 바꾸기
Chem.MolToMolBlock()


# Chem.ForwardSDMolSupplier() 는 SD 파일(.sdf)을 처음부터 하나씩 끝까지 순차적으로 읽어오는 도구.
  SDMolSupplier와 다르게 단방향성이다. (앞에서 쭉읽어들이기만 가능하고 특정 인덱스로 바로 이동은 불가능)
fp = gzip.open("data/actives_5ht3.sdf.gz")
suppl = Chem.ForwardSDMolSupplier(fp)


## m이 None(분자 문제가 있을 때)이 아니면, 즉 분자에 문제가 없으면 supple이라는 파일에서 하나씩 꺼내서 mols라는 리스트에 저장해라
mols = [m for m in suppl if m is not None]


# 분자들의 리스트가 있을때, 파일로 저장
with Chem.SDWriter("mols.sdf") as fout:  => mols.sdf라는 이름의 SDF 파일을 새로 만들고, 이를 작성할 도구(Writer)를 실행해 fout이라는 변수로 지정
  for m in mols:                         => mols라는 묶음(리스트나 Supplier 객체 등) 안에 들어있는 분자 객체들을 하나씩 꺼내어 m이라는 변수에 담아 반복
    fout.write(m)                        => 꺼내진 분자 m을 아까 열어둔 파일(fout)에 실제로 기록(Write)



# 수소를 붙일 때
=> 주의할점: AddHs를 사용하면 새로운 분자를 리턴하니, 새로운 변수를 지정해주어야한다.
y = Chem.AddHs(x)

# 수소를 지울 때
Chem.RemoveHs(x)


# MolToMolBlock은 결과물을 화면(텍스트)에 뿌려주지만, MolToMolFile은 결과물을 컴퓨터 파일(.mol)로 저장하는 함수.
Chem.MolToMolFile은 다음과 같은 형식으로 명령해야한다. Chem.MolToMolFile(분자, "data/파일명")
Chem.MolToMolFile(m4, "data/test.mol") # m4를 test.mol 파일로 저장하겠다.
